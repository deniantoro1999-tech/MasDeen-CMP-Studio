rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // Domain Validators
    function isValidUser() {
      return hasRequiredFields(['uid', 'email', 'createdAt']) &&
             request.resource.data.uid == request.auth.uid &&
             request.resource.data.email is string &&
             request.resource.data.createdAt is string;
    }

    function isValidProject() {
      return hasRequiredFields(['userId', 'title', 'createdAt', 'updatedAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidString('title', 0, 200) &&
             (!('artist' in request.resource.data) || isValidString('artist', 0, 200)) &&
             (!('coverUrl' in request.resource.data) || isValidString('coverUrl', 0, 2000)) &&
             (!('lyrics' in request.resource.data) || isValidString('lyrics', 0, 50000)) &&
             (!('syncData' in request.resource.data) || isValidString('syncData', 0, 100000));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser() && uidNotModified();
      allow delete: if isOwner(userId);
    }

    match /projects/{projectId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidProject() && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && isValidProject() && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }
  }
}
