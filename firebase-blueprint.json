{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A saved audio-visualizer project",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner UID" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "themeIdx": { "type": "number" },
        "visualIdx": { "type": "number" },
        "coverUrl": { "type": "string" },
        "lyrics": { "type": "string" },
        "syncData": { "type": "string", "description": "JSON stringified sync data" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "Project" },
      "description": "User projects"
    }
  }
}
